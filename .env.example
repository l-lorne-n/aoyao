# Tencent Cloud ASR credentials. Do not commit a real .env file.
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=

# Defaults for the MVP test.
TENCENT_REGION=ap-guangzhou
TENCENT_ASR_ENGINE=16k_zh_medical

# Optional: auto uses the official Tencent SDK when installed, otherwise HTTP signing.
# Set to http to avoid any SDK dependency, or sdk to require the SDK.
TENCENT_ASR_TRANSPORT=auto

# Optional: Tencent Cloud hotword table ID.
TENCENT_ASR_HOTWORD_ID=

# Optional: 0 keeps punctuation, 1 removes punctuation.
TENCENT_ASR_FILTER_PUNC=0

# Optional: encrypted Jianguoyun WebDAV backup.
# A local jianguoyun_key.txt file with the same keys is also supported.
BACKUP_WEBDAV_URL=https://dav.jianguoyun.com/dav/AoyaoBackup/
BACKUP_WEBDAV_USERNAME=
BACKUP_WEBDAV_PASSWORD=
BACKUP_ENCRYPTION_PASSWORD=
